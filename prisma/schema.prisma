// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  evidences    Evidence[]
  scanResults  ScanResult[]
  contacts     TrustedContact[]
}

model Evidence {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  type        String   // "text", "url", "screenshot", "call"
  content     String
  riskLevel   String   @default("unknown")
  tags        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScanResult {
  id          String   @id @default(cuid())
  userId      String
  input       String
  inputType   String   // "url", "text", "phone"
  riskScore   Int
  riskLevel   String   // "safe", "suspicious", "dangerous"
  explanation String
  indicators  String   @default("[]")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportedNumber {
  id          String   @id @default(cuid())
  phone       String   @unique
  reportCount Int      @default(1)
  category    String   // "robocall", "fraud", "telemarketing", "unknown"
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrustedContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  relation  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
